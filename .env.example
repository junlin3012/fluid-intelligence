# Fluid Intelligence — Local Development Environment
#
# Copy to .env and fill in values: cp .env.example .env
# Generate secrets with: openssl rand -base64 32

# === Required (generate each) ===
POSTGRES_PASS=
CONTEXTFORGE_DB_PASS=
KEYCLOAK_DB_PASS=
KC_ADMIN_PASS=
SSO_CLIENT_SECRET=dev-test-secret-change-in-prod
AUTH_ENCRYPTION_SECRET=

# === Optional (have defaults) ===
PLATFORM_ADMIN_EMAIL=admin@example.com
LOG_LEVEL=INFO
POSTGRES_USER=postgres
KC_ADMIN_USER=admin

# === Phase 3: Sidecars (fill when needed) ===
SHOPIFY_STORE=placeholder.myshopify.com
SHOPIFY_API_VERSION=2026-01
SHOPIFY_ACCESS_TOKEN=
APOLLO_GRAPH_REF=
APOLLO_KEY=
