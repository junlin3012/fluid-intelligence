# Fluid Intelligence — Environment Configuration
#
# This file documents ALL environment variables the system uses.
# Copy to .env and fill in YOUR values for local development.
# In production, values come from cloudbuild.yaml --set-env-vars and --set-secrets.
#
# REQUIRED = container crashes on startup if unset
# OPTIONAL = has sensible default shown in [brackets]
# SECRET   = must come from GCP Secret Manager in production (never commit values)

# ============================================================
# REQUIRED SECRETS (GCP Secret Manager in production)
# ============================================================
SHOPIFY_CLIENT_ID=              # SECRET: Shopify app client ID
SHOPIFY_CLIENT_SECRET=          # SECRET: Shopify app client secret
JWT_SECRET_KEY=                 # SECRET: ContextForge JWT signing key (HS256)
AUTH_PASSWORD=                  # SECRET: CLI password fallback for mcp-auth-proxy
GOOGLE_OAUTH_CLIENT_ID=         # SECRET: Google OAuth client ID
GOOGLE_OAUTH_CLIENT_SECRET=     # SECRET: Google OAuth client secret
DB_PASSWORD=                    # SECRET: PostgreSQL password
SHOPIFY_TOKEN_ENCRYPTION_KEY=   # SECRET: AES key for stored Shopify tokens
AUTH_ENCRYPTION_SECRET=         # SECRET: ContextForge DB encryption (MUST differ from JWT_SECRET_KEY)
CREDENTIALS_CONFIG=             # SECRET: Google Sheets service account JSON

# ============================================================
# REQUIRED BUSINESS CONFIG
# ============================================================
SHOPIFY_STORE=                  # REQUIRED: your-store.myshopify.com
SHOPIFY_API_VERSION=            # REQUIRED: e.g., 2026-01
EXTERNAL_URL=                   # REQUIRED: public hostname (no https://), e.g., my-gateway.run.app
GOOGLE_ALLOWED_USERS=           # REQUIRED: comma-separated emails allowed to OAuth login
PLATFORM_ADMIN_EMAIL=           # REQUIRED: bootstrap admin identity email
CLOUDSQL_INSTANCE=              # REQUIRED: GCP Cloud SQL instance (project:region:instance)

# ============================================================
# OPTIONAL — Database [defaults]
# ============================================================
# DB_USER=contextforge          # PostgreSQL username
# DB_NAME=contextforge          # PostgreSQL database name

# ============================================================
# OPTIONAL — Service Ports [defaults]
# ============================================================
# MCPGATEWAY_PORT=4444          # ContextForge listen port
# APOLLO_PORT=8000              # Apollo MCP Server port
# DEVMCP_PORT=8003              # dev-mcp bridge port
# SHEETS_PORT=8004              # google-sheets bridge port

# ============================================================
# OPTIONAL — Tool Versions [defaults]
# ============================================================
# DEVMCP_VERSION=1.7.1          # @shopify/dev-mcp npm package version
# SHEETS_VERSION=0.6.0          # mcp-google-sheets uv package version

# ============================================================
# OPTIONAL — Identity & RBAC [defaults]
# ============================================================
# PRIMARY_USER_EMAIL=           # [first email from GOOGLE_ALLOWED_USERS] for team/role bootstrap
# VIRTUAL_SERVER_NAME=fluid-intelligence  # ContextForge virtual server name
# TRUST_PROXY_AUTH=true
# TRUST_PROXY_AUTH_DANGEROUSLY=true
# MCP_CLIENT_AUTH_ENABLED=false
# PROXY_USER_HEADER=X-Authenticated-User
# AUTH_REQUIRED=true
# SSO_AUTO_CREATE_USERS=true
# SSO_GOOGLE_ADMIN_DOMAINS=     # Auto-promote users from this domain to admin

# ============================================================
# OPTIONAL — ContextForge [defaults]
# ============================================================
# MCG_PORT=4444
# MCG_HOST=0.0.0.0
# HOST=0.0.0.0
# GUNICORN_WORKERS=1
# HTTP_SERVER=gunicorn
# DB_POOL_SIZE=5
# PYTHONUNBUFFERED=1
# MCPGATEWAY_UI_ENABLED=false
# MCPGATEWAY_ADMIN_API_ENABLED=true
# TRANSPORT_TYPE=all
# CACHE_TYPE=database
# FEDERATION_TIMEOUT=60
# MIN_TOOL_COUNT=70

# ============================================================
# OPTIONAL — Security [defaults]
# ============================================================
# SSRF_PROTECTION_ENABLED=true
# SSRF_ALLOW_LOCALHOST=true
# SSRF_ALLOW_PRIVATE_NETWORKS=true

# ============================================================
# OPTIONAL — Observability [defaults]
# ============================================================
# OTEL_SERVICE_NAME=fluid-intelligence
# OTEL_EXPORTER_OTLP_ENDPOINT=https://cloudtrace.googleapis.com
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=none
