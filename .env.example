# Fluid Intelligence — Environment Variables
# Copy to .env and fill in values. All secrets are managed via GCP Secret Manager in production.

# --- Shopify ---
SHOPIFY_STORE=junlinleather-5148.myshopify.com
SHOPIFY_API_VERSION=2026-01
SHOPIFY_CLIENT_ID=              # Shopify app client ID (Secret Manager: shopify-client-id)
SHOPIFY_CLIENT_SECRET=          # Shopify app client secret (Secret Manager: shopify-client-secret)
SHOPIFY_TOKEN_ENCRYPTION_KEY=   # AES-256-GCM key, base64-encoded 256-bit (Secret Manager: shopify-token-encryption-key)

# --- Auth ---
AUTH_PASSWORD=                  # Platform admin password (Secret Manager: mcp-auth-passphrase)
AUTH_ENCRYPTION_SECRET=          # ContextForge DB encryption key (Secret Manager: auth-encryption-secret)
                                 # MUST be independent of JWT_SECRET_KEY — rotating JWT must NOT affect stored data
JWT_SECRET_KEY=                 # JWT signing secret (Secret Manager: mcp-jwt-secret)
GOOGLE_OAUTH_CLIENT_ID=        # Google OAuth client ID (Secret Manager: google-oauth-client-id)
GOOGLE_OAUTH_CLIENT_SECRET=    # Google OAuth client secret (Secret Manager: google-oauth-client-secret)
GOOGLE_ALLOWED_USERS=ourteam@junlinleather.com  # Comma-separated Google emails allowed to login
PLATFORM_ADMIN_EMAIL=admin@junlinleather.com
EXTERNAL_URL=fluid-intelligence-1056128102929.asia-southeast1.run.app  # Public URL (no https://)

# --- Database (Cloud SQL PostgreSQL) ---
DB_USER=contextforge
DB_NAME=contextforge
DB_PASSWORD=                   # Database password (Secret Manager: db-password)

# --- ContextForge ---
MCG_PORT=4444                  # ContextForge listen port (NOT PORT, which Cloud Run reserves)
MCG_HOST=0.0.0.0              # Bind address (must be 0.0.0.0 in containers)
MCPGATEWAY_PORT=4444           # Alias for MCG_PORT
HOST=0.0.0.0
GUNICORN_WORKERS=1
HTTP_SERVER=gunicorn
DB_POOL_SIZE=5                   # ContextForge default is 200 — MUST be ≤25 (Cloud SQL db-f1-micro connection limit)
PYTHONUNBUFFERED=1               # Immediate log output (no buffering)
MCPGATEWAY_UI_ENABLED=false
MCPGATEWAY_ADMIN_API_ENABLED=true
TRANSPORT_TYPE=all
AUTH_REQUIRED=false              # ContextForge auth disabled; mcp-auth-proxy handles external auth
CACHE_TYPE=database

# --- Security ---
SSRF_PROTECTION_ENABLED=true
SSRF_ALLOW_LOCALHOST=true      # Required for inter-service communication
SSRF_ALLOW_PRIVATE_NETWORKS=true

# --- Google Sheets ---
CREDENTIALS_CONFIG=            # Service account JSON (Secret Manager: google-sheets-credentials)
