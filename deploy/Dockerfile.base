# Dockerfile.base — All immutable dependencies (rebuild rarely)
# Contains: ContextForge + Apollo binary + mcp-auth-proxy + system deps
# Rebuild when: Apollo/ContextForge/auth-proxy version changes
# Build time: ~20 min (Apollo Rust compile dominates)

# Stage 1: Apollo MCP Server (Rust compile)
FROM rust:1.82-slim-bookworm AS apollo-builder

RUN apt-get update && apt-get install -y \
    pkg-config libssl-dev git make perl cmake \
    && rm -rf /var/lib/apt/lists/*

ENV OPENSSL_NO_VENDOR=1

ARG APOLLO_VERSION=v1.9.0
RUN git clone --depth 1 --branch ${APOLLO_VERSION} \
    https://github.com/apollographql/apollo-mcp-server.git /src
WORKDIR /src
RUN cargo build --release --locked

# Stage 2: mcp-auth-proxy binary (FORKED — identity forwarding patch)
# Fork: junlin3012/mcp-auth-proxy v2.5.4-identity
# Adds X-Authenticated-User header from JWT sub claim for ContextForge proxy auth
FROM alpine:3.20 AS authproxy
ADD https://github.com/junlin3012/mcp-auth-proxy/releases/download/v2.5.4-identity/mcp-auth-proxy-linux-amd64 /mcp-auth-proxy
RUN echo "024e25f576b2c485e5cf57b3624df1dbea288c8ee84df473024d53c5b11d4949  /mcp-auth-proxy" | sha256sum -c - && \
    chmod +x /mcp-auth-proxy

# Stage 3: Runtime — ContextForge base + all system deps + binaries
FROM ghcr.io/ibm/mcp-context-forge:1.0.0-RC-2

USER root

# System packages (nodejs for dev-mcp, npm for npx, curl/jq for bootstrap,
# util-linux for flock advisory lock, tar/gzip for uv install)
RUN microdnf install -y nodejs npm curl jq tar gzip util-linux && microdnf clean all

# uv (standalone binary — for mcp-google-sheets)
ARG UV_VERSION=0.10.10
RUN curl -fsSL https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/uv-x86_64-unknown-linux-gnu.tar.gz \
    | tar -xz --strip-components=1 -C /usr/local/bin

# psycopg2 for PostgreSQL (uv pip install corrupts mcpgateway CLI entry point,
# but we bypass it with direct main() invocation — see entrypoint.sh)
RUN uv pip install --python /app/.venv/bin/python psycopg2-binary==2.9.10

# tini (PID 1 init process)
RUN curl -fsSL https://github.com/krallin/tini/releases/download/v0.19.0/tini-amd64 \
      -o /usr/local/bin/tini && \
    echo "93dcc18adc78c65a028a84799ecf8ad40c936fdfc5f2a57b1acda5a8117fa82c  /usr/local/bin/tini" | sha256sum -c - && \
    chmod +x /usr/local/bin/tini

# Copy pre-compiled binaries
COPY --from=apollo-builder /src/target/release/apollo-mcp-server /usr/local/bin/apollo
COPY --from=authproxy /mcp-auth-proxy /usr/local/bin/mcp-auth-proxy
RUN chmod 755 /usr/local/bin/apollo /usr/local/bin/mcp-auth-proxy

# Verify ContextForge venv is intact
RUN /app/.venv/bin/python -c "from mcpgateway.cli import main; print('✓ mcpgateway OK')"
RUN /app/.venv/bin/python -c "import psycopg2; print('✓ psycopg2 OK')"

# Create data directory
RUN mkdir -p /app/data && chown -R 1001:0 /app

# Default to non-root user (thin Dockerfile also sets this)
USER 1001
